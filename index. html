<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayDirect | Smart Hotel Booking Prototype</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        .hotel-card:hover { transform: translateY(-5px); transition: 0.3s; }
        .gradient-bg { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); }
    </style>
</head>
<body class="bg-gray-100">

<div id="app">
    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-extrabold text-blue-700 tracking-tight">STAY<span class="text-gray-800">DIRECT</span></h1>
            <div class="flex space-x-4">
                <button @click="showAdmin = !showAdmin" class="text-sm font-semibold bg-gray-200 px-4 py-2 rounded-full hover:bg-gray-300">
                    {{ showAdmin ? 'Close Admin' : 'Admin Panel' }}
                </button>
            </div>
        </div>
    </nav>

    <div v-if="showAdmin" class="bg-yellow-50 border-b-2 border-yellow-200 p-6 animate-pulse">
        <div class="container mx-auto">
            <h2 class="font-bold text-yellow-800 mb-2 underline">Live Pricing Control (Global)</h2>
            <div class="flex items-center space-x-4">
                <span>Low Demand</span>
                <input type="range" v-model="multiplier" min="0.5" max="3" step="0.1" class="w-1/2 h-2 bg-blue-300 rounded-lg appearance-none cursor-pointer">
                <span>Peak Season (3x)</span>
            </div>
            <p class="mt-2 text-sm text-yellow-900 font-medium">Currently showing prices at <b>{{ multiplier }}x</b> multiplier based on live demand.</p>
        </div>
    </div>

    <div class="gradient-bg text-white py-12 px-6 text-center">
        <h2 class="text-4xl font-bold mb-4">Find Your Next Luxury Stay</h2>
        <p class="text-blue-100">Dynamic pricing. Direct bookings. Best deals.</p>
    </div>

    <div class="container mx-auto p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div v-for="hotel in hotels" :key="hotel.id" class="hotel-card bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="relative">
                <img :src="hotel.image" class="w-full h-56 object-cover" alt="Hotel image">
                <div class="absolute top-4 right-4 bg-white px-2 py-1 rounded-lg shadow-md font-bold text-sm">
                    ⭐ {{ hotel.rating }}
                </div>
            </div>
            
            <div class="p-5">
                <h3 class="text-xl font-bold text-gray-800">{{ hotel.name }}</h3>
                <p class="text-gray-500 text-sm mb-4"><i class="fas fa-map-marker-alt mr-2"></i>{{ hotel.location }}</p>
                
                <div class="flex justify-between items-end border-t pt-4">
                    <div>
                        <span class="text-xs text-red-500 line-through">₹{{ Math.round(hotel.price * 1.5) }}</span>
                        <div class="text-2xl font-black text-blue-600">₹{{ Math.round(hotel.price * multiplier) }}</div>
                        <span class="text-xs text-gray-400">per night + Taxes</span>
                    </div>
                    <button @click="bookNow(hotel)" class="bg-green-500 text-white px-5 py-2 rounded-xl font-bold hover:bg-green-600 transition flex items-center">
                        <i class="fab fa-whatsapp mr-2"></i> Book Now
                    </button>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-gray-900 text-white py-10 mt-10">
        <div class="container mx-auto text-center">
            <p class="mb-6 opacity-75 text-lg font-light">Follow our updates on social media</p>
            <div class="flex justify-center space-x-8 text-3xl mb-8">
                <a href="#" class="hover:text-blue-400"><i class="fab fa-facebook"></i></a>
                <a href="#" class="hover:text-pink-500"><i class="fab fa-instagram"></i></a>
                <a href="#" class="hover:text-blue-300"><i class="fab fa-twitter"></i></a>
                <a href="#" class="hover:text-red-500"><i class="fab fa-youtube"></i></a>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-widest border-t border-gray-800 pt-6">
                Ready for Exit Strategy: Built for Scalability & Global Integration
            </p>
        </div>
    </footer>
</div>

<script>
    const { createApp } = Vue

    createApp({
        data() {
            return {
                showAdmin: false,
                multiplier: 1.0,
                hotels: [
                    {
                        id: 1,
                        name: 'The Royal Heritage',
                        location: 'Jaipur, Rajasthan',
                        price: 4500,
                        rating: 4.8,
                        image: 'https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=800&q=80'
                    },
                    {
                        id: 2,
                        name: 'Ocean Breeze Resort',
                        location: 'Goa, India',
                        price: 7200,
                        rating: 4.9,
                        image: 'https://images.unsplash.com/photo-1571896349842-33c89424de2d?auto=format&fit=crop&w=800&q=80'
                    },
                    {
                        id: 3,
                        name: 'Mountain Peak Lodge',
                        location: 'Manali, HP',
                        price: 3800,
                        rating: 4.7,
                        image: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=800&q=80'
                    }
                ]
            }
        },
        methods: {
            bookNow(hotel) {
                const finalPrice = Math.round(hotel.price * this.multiplier);
                const message = `Hello, I want to book ${hotel.name} in ${hotel.location} at the price of ₹${finalPrice}. Please confirm availability.`;
                const whatsappUrl = `https://wa.me/91XXXXXXXXXX?text=${encodeURIComponent(message)}`;
                window.open(whatsappUrl, '_blank');
            }
        }
    }).mount('#app')
</script>

</body>
</html>
